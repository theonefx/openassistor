# OpenAssistor .env example
#
# Copy this file to .env and fill in the values you need.
#
# Model provider API keys (set at least one)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Qwen (通义千问) configuration
# QWEN_API_KEY=sk-...
# QWEN_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
# QWEN_MODEL=qwen-plus

# Gateway auth (recommended if binding beyond loopback)
# OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token

# Channels (only set what you enable)
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
